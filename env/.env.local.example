# Copy this file to env/.env.local before running locally.

# Built-in environment variables
TEAMSFX_ENV=local
APP_NAME_SUFFIX=local
CONNECTOR_ID=SFCRMDemoConnector2003
CONNECTOR_NAME=TanwiSF-CRM-2003
CONNECTOR_DESCRIPTION=Salesforce CRM Custom connector for Leads, Accounts, Contacts, Opportunities, Cases, and Customer Projects. This custom connector brings Salesforce Sales Cloud data into Microsoft Search and Microsoft 365 experiences. The content in this connection can also be referred to as SFDC, Salesforce data, or Salesforce Sales Cloud. Keywords: SFDC, accounts, buyers, contracts, purchasers, cases, leads, opportunities, contacts, customer projects

# Salesforce Configuration
SALESFORCE_INSTANCE_URL=https://your-org.salesforce.com
SALESFORCE_API_VERSION=v48.0
SALESFORCE_CLIENT_ID=your_salesforce_connected_app_client_id
SECRET_SALESFORCE_CLIENT_SECRET=your_salesforce_client_secret

# Azure AD App Configuration
AAD_APP_CLIENT_ID=your-azure-ad-client-id
AAD_APP_OBJECT_ID=your-azure-ad-object-id
AAD_APP_TENANT_ID=your-azure-ad-tenant-id
SECRET_AAD_APP_CLIENT_SECRET=your-azure-ad-client-secret
AAD_APP_OAUTH_AUTHORITY=https://login.microsoftonline.com/your-azure-ad-tenant-id
AAD_APP_OAUTH_AUTHORITY_HOST=https://login.microsoftonline.com

# Mock Data Configuration (for testing without live Salesforce)
# Set to 'true' to use mock data instead of real Salesforce API
# Set to 'false' or remove to use real Salesforce API
USE_MOCK_DATA=true
