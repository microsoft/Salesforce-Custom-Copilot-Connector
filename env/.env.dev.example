# Copy this file to env/.env.dev before provisioning a dev environment.

# Provisioning values used by m365agents.yml and infra/azure.parameters.json.
TEAMSFX_ENV=dev
CONNECTOR_ID=salesforcecrmcustomconnector
CONNECTOR_NAME=Salesforce-CRM-1803
CONNECTOR_DESCRIPTION=Salesforce CRM Custom connector for Leads, Accounts, Contacts, Opportunities, Cases, and Customer Projects.

# Updating Azure resources
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_RESOURCE_GROUP_NAME=your_resource_group_name
RESOURCE_SUFFIX=dev
CONNECTOR_REPOS=your_connector_repository_list

# AAD_APP_CLIENT_ID, AAD_APP_OBJECT_ID, AAD_APP_TENANT_ID,
# SECRET_AAD_APP_CLIENT_SECRET, AAD_APP_OAUTH_AUTHORITY, and
# AAD_APP_OAUTH_AUTHORITY_HOST are generated into the env files by the
# aadApp/create provision step when you use the default Microsoft 365 Agents
# Toolkit workflow.
