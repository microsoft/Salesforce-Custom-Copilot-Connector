# Copy this file to env/.env.dev.user before provisioning a dev environment.

# If you're adding a secret value, add SECRET_ prefix to the name so Microsoft 365 Agents Toolkit can handle them properly.
# Secrets. Keys prefixed with `SECRET_` will be masked in Microsoft 365 Agents Toolkit logs.

# The default aadApp/create provision step can write this value for you.
# Set it manually only when you are reusing an existing Entra app.
SECRET_AAD_APP_CLIENT_SECRET=your_azure_ad_app_client_secret
