{
  "type": "AdaptiveCard",
  "version": "1.3",
  "body": [
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "auto",
          "items": [
            {
              "type": "Image",
              "url": "https://searchuxcdn.blob.core.windows.net/designerapp/images/DefaultMRTIcon.png",
              "size": "Small",
              "horizontalAlignment": "Center",
              "altText": "Salesforce ${if(objectType, objectType, 'Item')}"
            }
          ],
          "height": "stretch"
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            {
              "type": "TextBlock",
              "text": "[${title}](${url})",
              "color": "Accent",
              "size": "Medium",
              "weight": "Bolder"
            },
            {
              "type": "TextBlock",
              "text": "${if(Email, Email, if(Phone, Phone, ''))}",
              "spacing": "Small",
              "isVisible": "${if(Email, true, if(Phone, true, false))}"
            },
            {
              "type": "TextBlock",
              "text": "${if(Company, Company, if(AccountName, AccountName, ''))}",
              "wrap": true,
              "spacing": "Small",
              "isVisible": "${if(Company, true, if(AccountName, true, false))}"
            },
            {
              "type": "TextBlock",
              "text": "${if(Description, substring(Description, 0, 150), '')}",
              "wrap": true,
              "spacing": "Small",
              "maxLines": 2,
              "isVisible": "${if(Description, true, false)}"
            },
            {
              "type": "FactSet",
              "facts": [
                {
                  "title": "Type:",
                  "value": "${objectType}"
                },
                {
                  "title": "${if(StageName, 'Stage', if(Status, 'Status', if(Priority, 'Priority', '')))}:",
                  "value": "${if(StageName, StageName, if(Status, Status, if(Priority, Priority, '')))}"
                }
              ],
              "spacing": "Small"
            }
          ],
          "horizontalAlignment": "Left",
          "spacing": "Medium"
        }
      ]
    }
  ],
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json"
}
